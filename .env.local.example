# ============================================================
# Property Management OS — environment variables
# Copy to .env.local and fill in real values.
# ============================================================

# ---- Clerk ----
# From https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin

# ---- Airtable ----
# Token: https://airtable.com/create/tokens (needs data.records:read/write on the base)
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base ID: looks like "appXXXXXXXXXXXXXX" — find in Airtable API docs for your base
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ---- Airtable table IDs ----
# Each value is a "tblXXXXXXXXXXXXXX" id from the duplicated base.
# Find them in https://airtable.com/appXXXXXXXXXXXXXX/api/docs (one per table).
AIRTABLE_TABLE_PROPERTIES=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_EXPENSES=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_DEPOSITS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_REPORTS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_HOUSEKEEPING=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_HOUSEKEEPERS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_RENTALS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_ROLES=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_VISITS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_VENDORS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_ITINERARY=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_MAINTENANCE=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_MAINTENANCE_CONFIG=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_HELP=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_ACTIVITY_LOGS=tblXXXXXXXXXXXXXX
